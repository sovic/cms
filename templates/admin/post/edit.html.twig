{% extends '@CmsBundle/admin/layout/admin.html.twig' %}
{% form_theme form '@CmsBundle/admin/forms/form-narrow.html.twig' %}
{% import '@CmsBundle/admin/macros/content-editor.html.twig' as content_editor %}
{% import '@CmsBundle/admin/macros/form.html.twig' as form_macro %}
{% import '@CmsBundle/admin/macros/gallery.html.twig' as gallery_macro %}

{% block content %}
    <div class="app-container container">
        <div class="{{ theme.default.card_class }}">
            {{ form_macro.card_header(theme, 'Editace příspěvku') }}

            <div class="card-body">
                {% if editing %}
                    <ul class="nav nav-tabs nav-line-tabs nav-line-tabs-2x border-0 fs-5 fw-semibold mb-8"
                        role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active"
                                    id="tab-form-btn"
                                    data-bs-toggle="tab"
                                    data-bs-target="#tab-form"
                                    type="button" role="tab"
                                    aria-selected="true">
                                Příspěvek
                            </button>
                        </li>
                        {{ gallery_macro.gallery_tabs_nav(galleries) }}
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab-form" role="tabpanel">
                            {{ block('edit_form') }}
                        </div>
                        {{ gallery_macro.gallery_tabs_panes('post', post.id, galleries) }}
                    </div>
                {% else %}
                    {{ block('edit_form') }}
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% block edit_form %}
    {{ form_start(form) }}
    {{ form_errors(form) }}

    {{ form_macro.section_header('Základní informace') }}
    <div class="row">
        <div class="col-6">
            {{ form_row(form.name) }}
        </div>
        <div class="col-6">
            {{ form_row(form.subtitle) }}
        </div>
        <div class="col-12">
            {{ form_row(form.public) }}
        </div>
    </div>
    <div class="row">
        <div class="col-12 col-md-6 col-lg-3">
            {{ form_row(form.publishDate) }}
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            {{ form_row(form.createDate) }}
        </div>
    </div>

    {{ form_macro.section_header('Obsah příspěvku') }}
    <div class="row">
        <div class="col-12">
            {{ form_row(form.content) }}
        </div>
        <div class="col-12">
            {{ form_row(form.perex) }}
        </div>
    </div>

    {{ form_macro.section_header('Metadata') }}
    <div class="row">
        <div class="col-6">
            {{ form_row(form.urlId) }}
        </div>
        <div class="col-6">
            {{ form_row(form.metaTitle) }}
        </div>
        <div class="col-12">
            {{ form_row(form.metaDescription) }}
        </div>
        <div class="col-12">
            {{ form_row(form.metaKeywords) }}
        </div>
    </div>

    <div class="position-sticky bottom-0 mt-2 py-5 bg-body border-top" id="page-sticky-bar">
        {% if form._token is defined %}
            {{ form_row(form._token) }}
        {% endif %}
        {% if form.save is defined %}
            {{ form_row(form.save) }}
        {% endif %}
    </div>
    <div class="mt-n5"></div>

    {{ form_end(form, {render_rest: true}) }}

    {{ content_editor.content_editor_basic('#post_content') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {% include '@CmsBundle/admin/partials/gallery-scripts.html.twig' %}
{% endblock %}