<!--suppress JSUnusedGlobalSymbols -->
{% if api_base_url is not defined %}
    {% set api_base_url = '' %}
{% endif %}

<script>
    function bindActions() {
        const $el = document.getElementsByClassName('action-button');
        for (let i = 0; i < $el.length; i++) {
            $el[i].addEventListener('click', function (event) {
                event.preventDefault();
                let method = $el[i].getAttribute('data-method');
                let parameters = JSON.parse($el[i].getAttribute('data-parameters'));
                let confirm = $el[i].getAttribute('data-confirm');
                let reload = true;
                if ($el[i].getAttribute('data-reload') === '0' || $el[i].getAttribute('data-reload') === 'false') {
                    reload = false;
                }
                if (confirm) {
                    if (window.confirm(confirm)) {
                        commitAction(method, parameters, reload);
                    }
                } else {
                    commitAction(method, parameters, reload);
                }
            });
        }
    }

    function bindGroupActions() {
        const $groupActionEl = document.getElementsByClassName('group-action');
        for (let i = 0; i < $groupActionEl.length; i++) {
            $groupActionEl[i].addEventListener('click', function (event) {
                event.preventDefault();
                let method = $groupActionEl[i].getAttribute('data-method');
                let ids = [];
                let $checkboxes = document.querySelectorAll('input.data-list-check:checked');
                $checkboxes.forEach(function ($checkbox) {
                    ids.push($checkbox.value);
                });
                let parameters = {
                    ids: ids,
                    parameters: JSON.parse($groupActionEl[i].getAttribute('data-parameters')),
                };

                if (ids.length <= 0) {
                    toastr.error('Nebyly vybrány žádné záznamy.');
                    return;
                }
                let confirm = $groupActionEl[i].getAttribute('data-confirm');
                if (confirm && !window.confirm(confirm)) {
                    return;
                }

                KTApp.showPageLoading();
                axios.post('{{ api_base_url }}/api/web/' + method, parameters).then(function (response) {
                    let data = response.data.data;
                    if (typeof data.message !== 'undefined') {
                        toastr.success(data.message);
                    }
                    if (typeof data.redirect !== 'undefined') {
                        window.location.href = data.redirect;
                        window.location.reload();
                    } else {
                        window.location.reload();
                    }
                    KTApp.hidePageLoading();
                }).catch(function (error) {
                    let msg = error.response.data.data.errors.concat('\n')
                    toastr.error(msg);
                    KTApp.hidePageLoading();
                });
            });
        }
    }

    function bindSearch() {
        let $form = document.getElementById('search');
        if (!$form) {
            return;
        }

        $form.addEventListener('submit', function (e) {
            e.preventDefault();
            search();
        });

        let $searchField = $form.querySelector('input[name="search"]');
        if ($searchField) {
            $searchField.addEventListener('change', function (e) {
                e.preventDefault();
                search();
            });
        }

        let $selectField = $form.querySelectorAll('select');
        if ($selectField) {
            $selectField.forEach(function (field) {
                if (field.closest('#advanced-filters-modal')) {
                    return;
                }
                field.addEventListener('change', function (e) {
                    e.preventDefault();
                    let name = field.name;
                    let value = field.options[field.selectedIndex].value;
                    let url = new URL(window.location.href);
                    url.searchParams.set(name, value);
                    url.searchParams.delete('page');
                    window.location.href = url.toString();
                });
            });
        }

        $form.querySelectorAll('.basic-filters input[type="checkbox"]').forEach(function ($checkbox) {
            $checkbox.addEventListener('change', function (e) {
                e.preventDefault();
                let url = new URL(window.location.href);
                let param = $checkbox.dataset.param || $checkbox.name;
                if ($checkbox.checked) {
                    url.searchParams.set(param, $checkbox.value);
                } else {
                    url.searchParams.delete(param);
                }
                url.searchParams.delete('page');
                window.location.href = url.toString();
            });
        });

        $form.querySelectorAll('.basic-filters input[type="date"]').forEach(function (input) {
            input.addEventListener('change', function () {
                const url = new URL(window.location.href);
                url.searchParams.delete('page');
                if (input.value) {
                    url.searchParams.set(input.name, input.value);
                } else {
                    url.searchParams.delete(input.name);
                }
                window.location.href = url.toString();
            });
        });

        let $resetEl = $form.querySelector('button[type="reset"]');
        if ($resetEl) {
            $resetEl.addEventListener('click', function (e) {
                e.preventDefault();
                window.location.href = window.location.href.split("?")[0];
            });
        }
    }

    function bindListSort() {
        const $sortEl = document.getElementsByClassName('dt-orderable-asc dt-orderable-desc');
        for (let i = 0; i < $sortEl.length; i++) {
            $sortEl[i].addEventListener('click', function (event) {
                event.preventDefault();
                let url = new URL(window.location.href);
                let sort = $sortEl[i].getAttribute('data-sort');
                let order;
                if ($sortEl[i].classList.contains('dt-ordering-asc')) {
                    order = 'desc';
                } else if ($sortEl[i].classList.contains('dt-ordering-desc')) {
                    order = '';
                    sort = '';
                } else {
                    order = 'asc';
                }
                url.searchParams.set('sort', sort);
                url.searchParams.set('order', order);
                window.location.href = url.toString();
            });
        }
    }

    function bindAdvancedFilters() {
        const modal = document.getElementById('advanced-filters-modal');
        if (!modal) {
            return;
        }

        const submitBtn = modal.querySelector('[data-advanced-filters-submit]');
        if (submitBtn) {
            submitBtn.addEventListener('click', function () {
                const url = new URL(window.location.href);
                url.searchParams.delete('page');

                modal.querySelectorAll('select').forEach(function (field) {
                    if (!field.name) return;
                    const value = field.options[field.selectedIndex].value;
                    if (value) {
                        url.searchParams.set(field.name, value);
                    } else {
                        url.searchParams.delete(field.name);
                    }
                });

                modal.querySelectorAll('input[type="checkbox"]').forEach(function (field) {
                    if (!field.name) return;
                    if (field.checked) {
                        url.searchParams.set(field.name, field.value && field.value !== '0' ? field.value : '1');
                    } else {
                        url.searchParams.delete(field.name);
                    }
                });

                modal.querySelectorAll('input[type="text"], input[type="number"]').forEach(function (field) {
                    if (!field.name) return;
                    if (field.value) {
                        url.searchParams.set(field.name, field.value);
                    } else {
                        url.searchParams.delete(field.name);
                    }
                });

                window.location.href = url.toString();
            });
        }

        const resetBtn = modal.querySelector('[data-advanced-filters-reset]');
        if (resetBtn) {
            resetBtn.addEventListener('click', function () {
                modal.querySelectorAll('select').forEach(function (field) {
                    field.selectedIndex = 0;
                });
                modal.querySelectorAll('input[type="checkbox"]').forEach(function (field) {
                    field.checked = false;
                });
                modal.querySelectorAll('input[type="text"], input[type="number"]').forEach(function (field) {
                    field.value = '';
                });
            });
        }
    }

    function commitAction(method, parameters, reload) {
        KTApp.showPageLoading();
        axios.post('{{ api_base_url }}/api/web/' + method, parameters).then(function (response) {
            let data = response.data.data;
            if (typeof data.message !== 'undefined') {
                toastr.success(data.message);
            }
            if (reload) {
                if (typeof data.redirect !== 'undefined') {
                    window.location.href = data.redirect;
                    window.location.reload();
                } else {
                    window.location.reload();
                }
            }
            KTApp.hidePageLoading();
        }).catch(function (error) {
            let msg = error.response.data.data.errors.concat('\n')
            toastr.error(msg);
            KTApp.hidePageLoading();
        });
    }

    function search() {
        let $form = document.getElementById('search');
        let search = $form.querySelector('input[name="search"]').value;
        let url = new URL(window.location.href);
        url.searchParams.set('search', search);
        url.searchParams.delete('page');
        window.location.href = url.toString();
    }

    document.addEventListener('DOMContentLoaded', function () {
        bindActions();
        bindGroupActions();
        bindSearch();
        bindListSort();
        bindAdvancedFilters();
    });

    document.addEventListener('DOMContentLoaded', function () {
        const $trEls = document.querySelectorAll('tr');
        for (let i = 0; i < $trEls.length; i++) {

            $trEls[i].addEventListener('mouseenter', function () {
                let $els = this.querySelector('.actions-wrapper-hover');
                if (!$els) {
                    return;
                }
                $els.classList.remove('d-none');
            });
            $trEls[i].addEventListener('mouseleave', function () {
                let $els = this.querySelector('.actions-wrapper-hover');
                if (!$els) {
                    return;
                }
                $els.classList.add('d-none');
            });
        }
    });

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('tr[data-href]').forEach(function (row) {
            row.addEventListener('click', function (e) {
                let clickedTd = e.target.closest('td');
                if (clickedTd && clickedTd.querySelector('.actions-wrapper')) {
                    return;
                }

                window.location.href = row.dataset.href;
            });
        });
    });
</script>
