{#
Variables:
  model         string  e.g. 'page', 'user'
  model_id      int     entity id
  model_name    string  gallery name (default = same as model)
  gallery_items array   result from Gallery::getItems() enriched with is_cover
#}
{% set model_name = model_name ?? model %}
<div class="gallery-grid"
     data-model="{{ model }}" data-model-id="{{ model_id }}"
     data-model-name="{{ model_name }}">
    <div class="gallery-grid-empty text-center py-16 text-gray-500 border border-dashed border-gray-300 rounded my-4 {{ gallery_items is not empty ? 'd-none' : '' }}">
        <i class="bi bi-images fs-3x mb-4 d-block"></i>
        <div class="fs-6">Galerie neobsahuje žádné položky.</div>
    </div>

    <div class="row g-4 gallery-grid-items {{ gallery_items is empty ? 'd-none' : '' }}">
        {% for item in gallery_items %}
            <div class="col-6 col-md-4 col-lg-3 gallery-item-col" id="gallery-item-{{ item.id }}">
                <div class="card card-flush shadow-sm h-100 {{ item.is_cover ? 'border border-primary' : '' }}"
                     data-item-id="{{ item.id }}">
                    <div class="card-body p-3 d-flex flex-column">
                        <a class="d-block overlay"
                           data-fslightbox="lightbox-basic"
                           href="{{ item.big }}">
                            <div class=" position-relative mb-3">
                                <img src="{{ item.small }}"
                                     alt="{{ item.name }}"
                                     class="img-fluid rounded w-100 overlay-wrapper"
                                     style="object-fit: cover; max-height: 160px;">
                                <span class="badge badge-primary position-absolute top-0 start-0 m-1 {{ item.is_cover ? '' : 'd-none' }}"
                                      id="cover-badge-{{ item.id }}">Titulní</span>
                                <button type="button"
                                        class="btn btn-icon btn-sm btn-color-white position-absolute top-0 end-0 m-1 js-gallery-delete"
                                        data-item-id="{{ item.id }}"
                                        title="Odebrat">
                                    <i class="bi bi-x-lg fs-6"></i>
                                </button>

                                <div class="overlay-layer card-rounded bg-dark bg-opacity-25 shadow">
                                    <i class="bi bi-eye-fill text-white fs-3x"></i>
                                </div>
                            </div>
                        </a>

                        <div class="fs-8 text-gray-600 mb-2 text-truncate"
                             title="{{ item.name }}">
                            {{ item.name }}{% if item.extension %}.{{ item.extension }}{% endif %}
                        </div>
                        {% if item.width and item.height %}
                            <div class="fs-8 text-gray-500 mb-3">{{ item.width }} × {{ item.height }} px</div>
                        {% endif %}

                        <div class="mt-auto d-flex gap-1">
                            <button type="button"
                                    class="btn btn-icon btn-sm btn-light-primary js-gallery-set-cover {{ item.is_cover ? 'active' : '' }}"
                                    data-item-id="{{ item.id }}"
                                    title="Nastavit jako titulní obrázek">
                                <i class="bi bi-star{{ item.is_cover ? '-fill' : '' }}"
                                   id="cover-icon-{{ item.id }}"></i>
                            </button>
                            <button type="button"
                                    class="btn btn-icon btn-sm btn-light js-gallery-move-left"
                                    data-item-id="{{ item.id }}"
                                    title="Posunout doleva">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button type="button"
                                    class="btn btn-icon btn-sm btn-light js-gallery-move-right"
                                    data-item-id="{{ item.id }}"
                                    title="Posunout doprava">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
