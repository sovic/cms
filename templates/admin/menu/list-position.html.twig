{% extends '@CmsBundle/admin/layout/data-list.html.twig' %}

{% import '@CmsBundle/admin/macros/data-list.html.twig' as data_list %}
{% import '@CmsBundle/admin/macros/form.html.twig' as form_macro %}
{% import '@CmsBundle/admin/macros/icons.html.twig' as icons %}

{% block title %}Menu – {{ position }}{% endblock %}

{% set allow_add = true %}
{% set is_search_enabled = false %}
{% set is_filters_enabled = false %}
{% set is_group_actions_enabled = false %}

{% block data_list_title %}
    <h2>
        {{ icons.back_to_list(path('admin:menu:list')) }}
        Menu
    </h2>
{% endblock %}

{% block add_item %}
    {% if allow_add %}
        <a class="btn btn-flex btn-light-primary"
           href="{{ path('admin:menu:edit', tree[0] is defined ? {'parent_id': tree[0].item.id} : {}) }}">
            <i class="ki-outline ki-message-add fs-3"></i>
            Nová položka
        </a>
    {% endif %}
{% endblock %}

{% macro render_tree(nodes, depth) %}
    {% for node in nodes %}
        {% set item = node.item %}
        {% set children = node.children %}
        {% set detail_url = path('admin:menu:edit', {'id': item.id}) %}
        <tr>
            <td>
                <div style="padding-left: {{ depth * 24 }}px;" class="d-flex align-items-center">
                    {% if depth > 0 %}
                        <i class="bi bi-arrow-return-right text-muted me-2"></i>
                    {% endif %}
                    <a href="{{ detail_url }}"
                       class="text-gray-800 text-hover-primary fs-5 fw-bold">
                        {{ item.name }}
                    </a>
                </div>
                <div style="padding-left: {{ depth * 24 }}px;">
                    <div class="js-toggle-switch"
                         data-entity="menu-item"
                         data-entity-id="{{ item.id }}"
                            {% if depth > 0 %}
                                style="padding-left: 20px; padding-top: 3px;"
                            {% endif %}
                    >
                        {% set icon = '<i class="bi bi-check-circle-fill ' ~ (item.isPublic ? 'text-success' : 'text-warning') ~ ' fs-3 ms-1 me-4"></i>' %}
                        {{ form_macro.switch('menu_item_is_public_' ~ item.id, icon, item.isPublic, null, 'is_public') }}
                    </div>
                    {% if item.visibility %}
                        {% if item.visibility == 'auth' %}
                            <span class="badge badge-light-primary">Pouze pro přihlášené</span>
                        {% endif %}
                        {% if item.visibility == 'not-auth' %}
                            <span class="badge badge-light-primary">Pouze pro nepřihlášené</span>
                        {% endif %}
                    {% endif %}
                </div>
            </td>
            <td>
                <div style="padding-left: {{ depth * 24 }}px;">
                    <i class="bi bi-arrow-return-right text-muted me-2"></i>
                    {% if depth > 0 %}
                        <span class="text-muted small">{{ item.sequence }}</span>
                    {% endif %}

                </div>
            </td>
            <td>
                {% if item.page %}
                    <span class="text-muted small">
                        <code>{{ item.page.urlId }}</code>
                    </span>
                {% elseif item.url %}
                    <span class="text-muted small">
                        <code>{{ item.url }}</code>
                    </span>
                {% endif %}
            </td>
            <td class="text-end">
                {% set actions = [] %}
                {% set actions = actions|merge([
                    {
                        'url': detail_url,
                        'title': 'Upravit',
                        'class': 'text-primary',
                        'icon': 'ki-duotone ki-pencil',
                    },
                ]) %}
                {{ data_list.actions_icons(actions) }}
            </td>
        </tr>
        {% if children|length > 0 %}
            {{ _self.render_tree(children, depth + 1) }}
        {% endif %}
    {% endfor %}
{% endmacro %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('bundles/cms/js/toggle-switch.js') }}"></script>
{% endblock %}

{% block data_list_table %}
    <table class="{{ theme.default.table_class }} dataTable">
        <thead>
        <tr class="{{ theme.default.thead_tr_class }}" role="row">
            <th class="min-w-300px" data-dt-column="1">
                <span class="dt-column-title">Název</span>
            </th>
            <th class="min-w-120px" data-dt-column="2">
                <span class="dt-column-title">Poř.</span>
            </th>
            <th class="min-w-200px" data-dt-column="3">
                <span class="dt-column-title">Odkaz</span>
            </th>
            <th class="text-end min-w-70px" data-dt-column="4" aria-label="Akce">
                <span class="dt-column-title">Akce</span>
            </th>
        </tr>
        </thead>
        <tbody class="{{ theme.default.tbody_class }}">
        {{ _self.render_tree(tree, 0) }}
        </tbody>
        <tfoot></tfoot>
    </table>
{% endblock %}
