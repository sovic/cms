{% extends '@CmsBundle/admin/layout/data-list.html.twig' %}

{% import '@CmsBundle/admin/macros/data-list.html.twig' as data_list %}
{% import '@CmsBundle/admin/macros/form.html.twig' as form_macro %}
{% import '@CmsBundle/admin/macros/icons.html.twig' as icons %}
{% import '@CmsBundle/admin/macros/theme.html.twig' as theme %}

{% block title %}Menu – {{ position }}{% endblock %}

{% set allow_add = true %}
{% set is_search_enabled = false %}
{% set is_filters_enabled = false %}
{% set is_group_actions_enabled = false %}

{% block data_list_title %}
    <h2>
        {{ icons.back_to_list(path('admin:menu:list')) }}
        Menu
    </h2>
{% endblock %}

{% block add_item %}
    {% if allow_add %}
        <a class="btn btn-flex btn-light-primary"
           href="{{ path('admin:menu:edit', tree[0] is defined ? {'parent_id': tree[0].item.id} : {}) }}">
            <i class="ki-outline ki-message-add fs-3"></i>
            Nová položka
        </a>
    {% endif %}
{% endblock %}

{% macro render_tree(nodes, depth) %}
    {% for node in nodes %}
        {% set item = node.item %}
        {% set children = node.children %}
        {% set detail_url = path('admin:menu:edit', {'id': item.id}) %}
        <tr>
            <td>
                <div style="padding-left: {{ depth * 24 }}px;" class="d-flex align-items-center">
                    {% if depth > 0 %}
                        <i class="bi bi-arrow-return-right text-muted me-2"></i>
                    {% endif %}
                    <a href="{{ detail_url }}"
                       class="text-gray-800 text-hover-primary fs-5 fw-bold">
                        {{ item.name }}
                    </a>
                </div>
                <div style="padding-left: {{ depth * 24 }}px;">
                    <div class="{{ theme.toggle_switch_class }}"
                         data-entity="menu-item"
                         data-entity-id="{{ item.id }}">
                        {% set icon = '<i class="bi bi-check-circle-fill ' ~ (item.isPublic ? 'text-success' : 'text-warning') ~ ' fs-3 ms-1 me-4"></i>' %}
                        {% set icon_switched = '<i class="bi bi-check-circle-fill ' ~ (item.isPublic ? 'text-warning' : 'text-success') ~ ' fs-3 ms-1 me-4"></i>' %}
                        {{ form_macro.switch('menu_item_is_public_' ~ item.id, icon, item.isPublic, null, 'is_public', icon_switched) }}
                    </div>
                    {% if item.visibility %}
                        {% if item.visibility == 'auth' %}
                            <span class="badge badge-light-primary ms-1">Pouze pro přihlášené</span>
                        {% endif %}
                        {% if item.visibility == 'not-auth' %}
                            <span class="badge badge-light-primary ms-1">Pouze pro nepřihlášené</span>
                        {% endif %}
                    {% endif %}
                </div>
            </td>
            <td>
                <div class="d-flex align-items-center gap-1" style="padding-left: {{ depth * 24 }}px;">
                    {% if not loop.first %}
                        <button type="button"
                                class="btn btn-sm btn-icon btn-light js-menu-reorder-btn"
                                data-id="{{ item.id }}"
                                data-direction="up"
                                title="Nahoru">
                            <i class="bi bi-arrow-up fs-8"></i>
                        </button>
                    {% else %}
                        <span class="btn btn-sm btn-icon invisible">
                            <i class="bi bi-arrow-up fs-8"></i>
                        </span>
                    {% endif %}

                    {% if not loop.last %}
                        <button type="button"
                                class="btn btn-sm btn-icon btn-light js-menu-reorder-btn"
                                data-id="{{ item.id }}"
                                data-direction="down"
                                title="Dolů">
                            <i class="bi bi-arrow-down fs-8"></i>
                        </button>
                    {% else %}
                        <span class="btn btn-sm btn-icon invisible">
                            <i class="bi bi-arrow-down fs-8"></i>
                        </span>
                    {% endif %}
                </div>
            </td>
            <td>
                {% if item.page %}
                    <a class="badge badge-info small"
                       target="_blank"
                       href="{{ item.page.urlId }}">
                        {{ item.page.urlId }}
                    </a>
                {% elseif item.url %}
                    <a class="badge badge-info small"
                       target="_blank"
                       href="{{ item.url }}">
                        {{ item.url }}
                    </a>
                {% endif %}
            </td>
            <td class="text-end">
                {% set actions = [] %}
                {% set actions = actions|merge([
                    {
                        'url': detail_url,
                        'title': 'Upravit',
                        'class': 'text-primary',
                        'icon': 'ki-duotone ki-pencil',
                    },
                    {
                        'url': '#',
                        'title': 'Smazat',
                        'method': 'menu-item/' ~ item.id ~ '/delete',
                        'confirm': 'Opravdu chcete smazat tuto položku?',
                        'btn_class': 'btn-active-light-danger action-button',
                        'icon': 'ki-duotone ki-trash',
                    },
                ]) %}
                {{ data_list.actions_icons(actions) }}
            </td>
        </tr>
        {% if children|length > 0 %}
            {{ _self.render_tree(children, depth + 1) }}
        {% endif %}
    {% endfor %}
{% endmacro %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('bundles/cms/js/toggle-switch.js') }}"></script>
    <!--suppress JSUnresolvedReference -->
    <script>
        (function () {
            document.querySelectorAll('.js-menu-reorder-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const id = btn.dataset.id;
                    const direction = btn.dataset.direction;
                    btn.disabled = true;
                    axios.post('/admin/api/web/menu-item/' + id + '/move', {direction: direction})
                        .then(function (response) {
                            if (response.data && response.data.status === 'success') {
                                window.location.reload();
                            } else {
                                btn.disabled = false;
                            }
                        })
                        .catch(function () {
                            btn.disabled = false;
                        });
                });
            });
        })();
    </script>
{% endblock %}

{% block data_list_table %}
    <table class="{{ theme.table_class }} dataTable">
        <thead>
        <tr class="{{ theme.thead_tr_class }}" role="row">
            <th class="min-w-300px" data-dt-column="1">
                <span class="dt-column-title">Název</span>
            </th>
            <th class="min-w-120px" data-dt-column="2"></th>
            <th class="min-w-200px" data-dt-column="3">
                <span class="dt-column-title">Odkaz</span>
            </th>
            <th class="text-end min-w-125px" data-dt-column="4" aria-label="Akce">
                <span class="dt-column-title">Akce</span>
            </th>
        </tr>
        </thead>
        <tbody class="{{ theme.tbody_class }}">
        {{ _self.render_tree(tree, 0) }}
        </tbody>
        <tfoot></tfoot>
    </table>
{% endblock %}
