{% extends '@CmsBundle/admin/layout/admin.html.twig' %}
{% form_theme form '@CmsBundle/admin/forms/form-narrow.html.twig' %}
{% import '@CmsBundle/admin/macros/content-editor.html.twig' as content_editor %}
{% import '@CmsBundle/admin/macros/form.html.twig' as form_macro %}
{% import '@CmsBundle/admin/macros/gallery.html.twig' as gallery_macro %}
{% import '@CmsBundle/admin/macros/tags.html.twig' as tags %}
{% import '@CmsBundle/admin/macros/theme.html.twig' as theme %}

{% block content %}
    <div class="app-container container-xxl">
        <div class="d-flex flex-column flex-xl-row">
            {% if editing %}
                {{ block('sidebar') }}
            {% endif %}

            <div class="flex-lg-row-fluid ms-lg-10">
                {{ block('tabs') }}

                <div class="tab-content">
                    <div class="tab-pane fade show active" role="tabpanel">
                        {{ block('tab_content') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block sidebar %}
    <div class="flex-column flex-lg-row-auto w-100 w-xl-300px mb-10">
        <div class="{{ theme.card_class }}">
            <div class="card-body pt-15 d-flex flex-column gap-3">
                {% if editing %}
                    <a class="btn btn-flex btn-sm btn-light-primary w-100" href="/{{ page.urlId }}" target="_blank">
                        <i class="bi bi-globe me-1"></i>
                        Stránka na webu
                    </a>
                    {% if page.pageGroup %}
                        <a class="btn btn-flex btn-sm btn-light-info w-100"
                           href="{{ path('admin:page:list', {'group_id': page.pageGroup.id}) }}">
                            <i class="bi bi-folder me-1"></i>
                            {{ page.pageGroup.name }}
                        </a>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% block tabs %}
    {% if editing %}
        <ul class="{{ theme.nav_tabs_class }}" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active"
                        id="tab-form-btn"
                        data-bs-toggle="tab"
                        data-bs-target="#tab-form"
                        type="button"
                        role="tab"
                        aria-selected="true">
                    Stránka
                </button>
            </li>
            {{ gallery_macro.gallery_tabs_nav(galleries) }}
        </ul>
    {% endif %}
{% endblock %}

{% block tab_content %}
    {% if editing %}
        {{ block('quick_settings') }}
    {% endif %}

    {{ block('edit_card') }}
{% endblock %}

{% block quick_settings %}
    <div class="{{ theme.card_class }}">
        <div class="card-header border-0">
            <div class="card-title">
                <h2>Rychlé nastavení</h2>
            </div>
        </div>
        <div class="card-body pt-0 pb-8">
            <div class="{{ theme.toggle_switch_class() }}"
                 data-entity="page"
                 data-entity-id="{{ page.id }}">
                {{ form_macro.switch('page_is_public_' ~ page.id, 'is_public', 'Publikováno', page.isPublic) }}
                {{ form_macro.switch('page_is_in_sitemap_' ~ page.id, 'is_in_sitemap', 'Sitemap', page.isInSitemap) }}
                {{ form_macro.switch('page_has_toc_' ~ page.id, 'has_toc', 'TOC', page.hasToc) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block edit_card %}
    {{ form_start(form) }}
    {{ form_errors(form) }}

    <div class="{{ theme.card_class }}">
        <div class="card-body">
            {{ block('edit_form') }}
        </div>
    </div>

    {{ form_end(form, {render_rest: false}) }}

    {{ content_editor.content_editor_basic('#page_content') }}
{% endblock %}

{% block edit_form %}
    {{ form_macro.section_header('Základní') }}

    <div class="row mb-4">
        <div class="col-12 col-md-6">
            {{ form_row(form.name) }}
        </div>
        <div class="col-12 col-lg-6">
            {{ form_row(form.pageGroup) }}
        </div>
        <div class="col-12 col-lg-6">
            {{ form_row(form.heading) }}
        </div>
        <div class="col-12 col-lg-6">
            {{ form_row(form.urlId) }}
        </div>
        {% if not editing %}
            <div class="col-12">
                {{ form_row(form.isPublic) }}
            </div>
        {% endif %}
    </div>

    {{ form_macro.section_header('Obsah stránky') }}
    <div class="row mb-4">
        <div class="col-12">
            {{ form_row(form.content) }}
        </div>
    </div>

    {{ form_macro.section_header('Štítky') }}
    <div class="row mb-4">
        {{ tags.tags('page_tags', page_tags) }}
    </div>

    {{ form_macro.section_header('Nastavení') }}
    <div class="row mb-4">
        <div class="col-12 col-md-6">
            {{ form_row(form.menuItem) }}
        </div>
    </div>

    {{ form_macro.section_header('Metadata') }}
    <div class="row">
        <div class="col-6">
            {{ form_row(form.metaTitle) }}
        </div>
        <div class="col-6">
            {{ form_row(form.metaKeywords) }}
        </div>
        <div class="col-12">
            {{ form_row(form.metaDescription) }}
        </div>
    </div>

    <div class="{{ theme.form_sticky_bar_class() }}"
         id="page-sticky-bar"
         data-hide-except-tab="tab-form">
        {% if form._token is defined %}
            {{ form_row(form._token) }}
        {% endif %}
        {% if form.save is defined %}
            {{ form_row(form.save) }}
        {% endif %}
    </div>
    <div class="mt-n5"></div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('bundles/cms/js/tabs.js') }}"></script>
    <script src="{{ asset('bundles/cms/js/toggle-switch.js') }}"></script>
    {% include '@CmsBundle/admin/partials/gallery-scripts.html.twig' %}
{% endblock %}
