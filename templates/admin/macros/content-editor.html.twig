{% macro content_editor_basic(selector, base_url = null, language = 'cs') %}
    <style>{{ selector }}
        {
            visibility: hidden
        ;
        }</style>
    <script src="{{ asset('bundles/cms/plugins/custom/tinymce/tinymce.bundle.js') }}"></script>
    <!--suppress JSUnresolvedReference, SpellCheckingInspection -->
    <script>
        const $el = document.querySelector('{{ selector }}');
        if ($el) {
            const options = {
                selector: '{{ selector }}',
                height: "480",
                menubar: false,
                toolbar: [
                    "undo redo | styleselect | bold italic | nonbreaking | bullist numlist | link | image | code | fullscreen"
                ],
                plugins: "autolink link code lists image fullscreen nonbreaking",
                relative_urls: false,
                {% if base_url %}document_base_url: '{{ base_url }}',{% endif %}
                browser_spellcheck: true,
                body_attrs: {spellcheck: 'true'},
                language_url: '{{ asset('bundles/cms/plugins/custom/tinymce/langs/' ~ language ~ '.js') }}',
                language: '{{ language }}',
                link_class_list: [
                    {title: 'None', value: ''},
                    {title: 'External Link', value: 'ext_link'},
                    {title: 'CTA link', value: 'int_cta_link'},
                ],
                content_style: ".int_cta_link { display: inline-block; padding: 9px 20px 10px 20px; background-color: #007bff; color: #ffffff !important; text-decoration: none; border-radius: 5px; }",
                init_instance_callback: function (editor) {
                    editor.getContainer().style.visibility = 'visible';
                },
                urlconverter_callback: function (url) {
                    // ignore urls that contain a placeholder, e.g. {link}, {unsubscribe_url}, etc.
                    if (url.indexOf('{') !== -1) {
                        return url;
                    }
                    // use documentBaseURI.toAbsolute to avoid recursive call back into urlconverter_callback
                    return this.documentBaseURI.toAbsolute(url);
                },
            };

            tinymce.init(options);
        }
    </script>
{% endmacro %}
