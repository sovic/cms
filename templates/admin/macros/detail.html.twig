{% macro info_row(label, value) %}
    <div class="fw-bold mt-3">{{ label }}</div>
    <div class="text-gray-600">{{ value ? value|raw : '-' }}</div>
{% endmacro %}

{% macro date_row(label, date, show_time = true) %}
    <div class="fw-bold mt-3">{{ label }}</div>
    <div class="text-gray-600">
        {%- if date -%}
            {% if show_time %}
                {{ date|format_date_time }}
            {% else %}
                {{ date|format_date }}
            {% endif %}
        {%- else -%}
            -
        {%- endif -%}
    </div>
{% endmacro %}

{% macro empty_data_card(theme, title) %}
    <div class="{{ theme.default.card_class }}">
        <div class="card-body">
            <div class="text-gray-600">{{ title }}</div>
        </div>
    </div>
{% endmacro %}

{% macro tab(label, route_path, current_path) %}
    <li class="nav-item" role="presentation">
        <a class="nav-link text-active-primary pb-4 {{ current_path == route_path ? 'active' : '' }}"
           href="{{ route_path }}"
           role="tab">
            {{ label }}
        </a>
    </li>
{% endmacro %}
